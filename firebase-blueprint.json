{
  "entities": {
    "UserProgress": {
      "title": "User Progress",
      "description": "Tracks completion and ratings for each level.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user." },
        "completedLevels": { "type": "array", "items": { "type": "integer" }, "description": "List of completed level IDs." },
        "efficiencyRatings": { "type": "object", "description": "Map of level ID to efficiency score." },
        "safetyRatings": { "type": "object", "description": "Map of level ID to safety score." },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "completedLevels"]
    },
    "LevelAnalytics": {
      "title": "Level Analytics",
      "description": "Aggregated data for level difficulty tuning.",
      "type": "object",
      "properties": {
        "levelId": { "type": "integer" },
        "failCount": { "type": "integer" },
        "averageTime": { "type": "number" },
        "commonShortCircuits": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["levelId"]
    }
  },
  "firestore": {
    "/users/{userId}/progress/data": {
      "schema": "UserProgress",
      "description": "Individual user progress data."
    },
    "/analytics/levels/{levelId}": {
      "schema": "LevelAnalytics",
      "description": "Global level analytics."
    }
  }
}
