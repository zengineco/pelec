rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}/progress/data
    // Fields:
    //   - userId: string (required)
    //   - completedLevels: list (required)
    //   - efficiencyRatings: map (optional)
    //   - safetyRatings: map (optional)
    //   - updatedAt: timestamp (optional)
    //
    // Collection: /analytics/levels/{levelId}
    // Fields:
    //   - levelId: int (required)
    //   - failCount: int (optional)
    //   - averageTime: float (optional)
    //   - commonShortCircuits: list (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "vg188705@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUserProgress(data) {
      return data.keys().hasAll(['userId', 'completedLevels']) &&
             data.userId is string &&
             data.completedLevels is list &&
             (!('efficiencyRatings' in data) || data.efficiencyRatings is map) &&
             (!('safetyRatings' in data) || data.safetyRatings is map);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User Progress
    match /users/{userId}/progress/data {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUserProgress(request.resource.data) && request.resource.data.userId == userId;
      allow update: if isOwner(userId) && isValidUserProgress(request.resource.data) && request.resource.data.userId == userId;
      allow delete: if isAdmin();
    }

    // Analytics (Publicly writable for game feedback, but only admin readable)
    match /analytics/levels/{levelId} {
      allow read: if isAdmin();
      allow write: if isAuthenticated(); // Allow users to submit analytics
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
